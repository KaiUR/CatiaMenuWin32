#include <windows.h>

101 ICON "app_icon.ico"

CREATEPROCESS_MANIFEST_RESOURCE_ID RT_MANIFEST "app.manifest"

200 MENU
BEGIN
    POPUP "&File"
    BEGIN
        MENUITEM "&Refresh + Sync\tF5",   201
        MENUITEM SEPARATOR
        MENUITEM "S&ettings...",          202
        MENUITEM SEPARATOR
        MENUITEM "E&xit",                 203
    END
    POPUP "&Run"
    BEGIN
        MENUITEM "Run &Last Script\tF9",  204
        MENUITEM SEPARATOR
        MENUITEM "Open &Cache Folder...", 205
        MENUITEM "Update &Dependencies",  208
    END
    POPUP "&View"
    BEGIN
        MENUITEM "Always on &Top",        209
        MENUITEM SEPARATOR
        POPUP "&Theme"
        BEGIN
            MENUITEM "&Dark",             213
            MENUITEM "&Light",            214
            MENUITEM "&System (default)", 215
        END
    END
    POPUP "&Window"
    BEGIN
        MENUITEM "Minimize to &Tray",     210
        MENUITEM "Start &with Windows",   211
        MENUITEM "Start &Minimized",      212
    END
    POPUP "&Help"
    BEGIN
        MENUITEM "&About",                206
        MENUITEM "View on &GitHub",       207
    END
END

300 DIALOG 0, 0, 340, 258
STYLE DS_SETFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Settings"
FONT 9, "Segoe UI"
BEGIN
    GROUPBOX "Python Interpreter", -1, 7, 7, 326, 40
    LTEXT "Path:", -1, 14, 22, 28, 10
    EDITTEXT 401, 46, 20, 234, 14, ES_AUTOHSCROLL
    PUSHBUTTON "Browse...", 402, 284, 19, 44, 16

    GROUPBOX "Script Cache Folder", -1, 7, 52, 326, 40
    LTEXT "Path:", -1, 14, 67, 28, 10
    EDITTEXT 403, 46, 65, 234, 14, ES_AUTOHSCROLL | ES_READONLY
    PUSHBUTTON "Browse...", 404, 284, 64, 44, 16

    GROUPBOX "Sync && Updates", -1, 7, 97, 326, 56
    AUTOCHECKBOX "Sync scripts automatically on startup", 409, 14, 112, 220, 12
    AUTOCHECKBOX "Always download latest script before running", 405, 14, 128, 220, 12
    AUTOCHECKBOX "Check for app updates on startup", 411, 14, 144, 220, 12

    GROUPBOX "Console Options", -1, 7, 158, 326, 42
    AUTOCHECKBOX "Show Python console window when running", 406, 14, 173, 220, 12
    AUTOCHECKBOX "Keep console open after script finishes (to see output/errors)", 410, 24, 188, 300, 12

    GROUPBOX "GitHub Token (optional - higher API rate limit)", -1, 7, 205, 326, 36
    AUTOCHECKBOX "Use token", 407, 14, 220, 60, 12
    EDITTEXT 408, 78, 218, 236, 14, ES_PASSWORD | ES_AUTOHSCROLL

    DEFPUSHBUTTON "OK", 1, 224, 236, 58, 16
    PUSHBUTTON "Cancel", 2, 288, 236, 50, 16
END

301 DIALOG 0, 0, 260, 145
STYLE DS_SETFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "About CatiaMenuWin32"
FONT 9, "Segoe UI"
BEGIN
    ICON 101, -1, 7, 8, 20, 20
    LTEXT "CatiaMenuWin32", -1, 36, 9, 210, 11
    LTEXT "PyCATIA script launcher for CATIA V5.", -1, 7, 30, 246, 10
    LTEXT "Scripts sourced from KaiUR/Pycatia_Scripts on GitHub.", -1, 7, 42, 246, 10
    LTEXT "Author: Kai-Uwe Rathjen", -1, 7, 62, 246, 10
    LTEXT "AI Assistance: Claude (Anthropic)", -1, 7, 74, 246, 10
    LTEXT "License: MIT", -1, 7, 86, 246, 10
    LTEXT "https://github.com/KaiUR/CatiaMenuWin32", -1, 7, 98, 246, 10
    DEFPUSHBUTTON "OK", 1, 105, 122, 50, 14
END

VS_VERSION_INFO VERSIONINFO
FILEVERSION 1,0,0,0
PRODUCTVERSION 1,0,0,0
FILEFLAGSMASK VS_FFI_FILEFLAGSMASK
FILEFLAGS 0
FILEOS VOS_NT_WINDOWS32
FILETYPE VFT_APP
FILESUBTYPE VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904B0"
        BEGIN
            VALUE "CompanyName",      "Kai-Uwe Rathjen"
            VALUE "FileDescription",  "CatiaMenuWin32 - PyCATIA Script Launcher"
            VALUE "FileVersion",      "1.0.0.0"
            VALUE "InternalName",     "CatiaMenuWin32"
            VALUE "LegalCopyright",   "Copyright 2025 Kai-Uwe Rathjen"
            VALUE "OriginalFilename", "CatiaMenuWin32.exe"
            VALUE "ProductName",      "CatiaMenuWin32"
            VALUE "ProductVersion",   "1.0.0.0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 0x04B0
    END
END
