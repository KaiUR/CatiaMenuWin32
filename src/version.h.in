#ifndef VERSION_H
#define VERSION_H

#define VERSION_MAJOR     @PROJECT_VERSION_MAJOR@
#define VERSION_MINOR     @PROJECT_VERSION_MINOR@
#define VERSION_PATCH     @PROJECT_VERSION_PATCH@
#define VERSION_BUILD     @BUILD_NUMBER@
#define IS_LOCAL_BUILD    @IS_LOCAL_BUILD@

#define VERSION_STRING    "@PROJECT_VERSION_MAJOR@.@PROJECT_VERSION_MINOR@.@PROJECT_VERSION_PATCH@.@BUILD_NUMBER@"
#define VERSION_STRING_W   L"@PROJECT_VERSION_MAJOR@.@PROJECT_VERSION_MINOR@.@PROJECT_VERSION_PATCH@.@BUILD_NUMBER@"
#define BUILD_DATE         "@CURRENT_DATE@"
#define BUILD_DATE_W       L"@CURRENT_DATE@"
#define BUILD_YEAR_W       L"@CURRENT_YEAR@"

/* Local dev build shows "dev" suffix and skips update check */
#if IS_LOCAL_BUILD
#define VERSION_DISPLAY_W  L"@PROJECT_VERSION_MAJOR@.@PROJECT_VERSION_MINOR@.@PROJECT_VERSION_PATCH@.@BUILD_NUMBER@ (local)"
#else
#define VERSION_DISPLAY_W  L"@PROJECT_VERSION_MAJOR@.@PROJECT_VERSION_MINOR@.@PROJECT_VERSION_PATCH@.@BUILD_NUMBER@"
#endif

#endif /* VERSION_H */
