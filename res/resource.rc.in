#include <windows.h>

101 ICON "app_icon.ico"

CREATEPROCESS_MANIFEST_RESOURCE_ID RT_MANIFEST "app.manifest"

200 MENU
BEGIN
    POPUP "&File"
    BEGIN
        MENUITEM "&Refresh + Sync\tF5",   201
        MENUITEM SEPARATOR
        MENUITEM "S&ettings...",          202
        MENUITEM "S&ources...",           217
        MENUITEM SEPARATOR
        MENUITEM "E&xit",                 203
    END
    POPUP "&Run"
    BEGIN
        MENUITEM "Run &Last Script\tF9",  204
        MENUITEM SEPARATOR
        MENUITEM "Open &Cache Folder...", 205
        MENUITEM "Update &Dependencies",  208
    END
    POPUP "&View"
    BEGIN
        MENUITEM "Always on &Top",        209
        MENUITEM SEPARATOR
        POPUP "&Theme"
        BEGIN
            MENUITEM "&Dark",             213
            MENUITEM "&Light",            214
            MENUITEM "&System (default)", 215
        END
    END
    POPUP "&Window"
    BEGIN
        MENUITEM "Minimize to &Tray",     210
        MENUITEM "Start &with Windows",   211
        MENUITEM "Start &Minimized",      212
    END
    POPUP "&Help"
    BEGIN
        MENUITEM "&About",                206
        MENUITEM "View on &GitHub",       207
    END
END

300 DIALOG 0, 0, 340, 318
STYLE DS_SETFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Settings"
FONT 9, "Segoe UI"
BEGIN
    GROUPBOX "Python Interpreter", -1, 7, 7, 326, 40
    LTEXT "Path:", -1, 14, 22, 28, 10
    EDITTEXT 401, 46, 20, 234, 14, ES_AUTOHSCROLL
    PUSHBUTTON "Browse...", 402, 284, 19, 44, 16

    GROUPBOX "Script Cache Folder", -1, 7, 52, 326, 40
    LTEXT "Path:", -1, 14, 67, 28, 10
    EDITTEXT 403, 46, 65, 234, 14, ES_AUTOHSCROLL | ES_READONLY
    PUSHBUTTON "Browse...", 404, 284, 64, 44, 16

    GROUPBOX "Sync && Updates", -1, 7, 97, 326, 94
    AUTOCHECKBOX "Sync scripts automatically on startup",       409, 14, 112, 220, 12
    AUTOCHECKBOX "Always download latest script before running",405, 14, 126, 220, 12
    AUTOCHECKBOX "Check for app updates on startup",            411, 14, 140, 180, 12
    AUTOCHECKBOX "Auto-install updates",                        413, 14, 154, 140, 12
    LTEXT "Auto-refresh every", -1, 14, 170, 80, 10
    EDITTEXT 414, 98, 168, 30, 14, ES_NUMBER
    LTEXT "hours (0 = off)", -1, 132, 170, 70, 10

    GROUPBOX "Console Options", -1, 7, 196, 326, 56
    AUTOCHECKBOX "Show Python console window when running",              406, 14, 211, 220, 12
    AUTOCHECKBOX "Keep console open after script finishes (to see errors)", 410, 24, 225, 296, 12
    AUTOCHECKBOX "Keep Update Deps console open until closed",           412, 14, 241, 296, 12

    GROUPBOX "GitHub Token (optional - higher API rate limit)", -1, 7, 257, 326, 36
    AUTOCHECKBOX "Use token", 407, 14, 272, 60, 12
    EDITTEXT 408, 78, 270, 236, 14, ES_PASSWORD | ES_AUTOHSCROLL

    PUSHBUTTON "Reset to Defaults", 420, 7, 298, 90, 16
    DEFPUSHBUTTON "OK", 1, 224, 298, 58, 16
    PUSHBUTTON "Cancel", 2, 288, 298, 50, 16
END

301 DIALOG 0, 0, 260, 145
STYLE DS_SETFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "About CatiaMenuWin32"
FONT 9, "Segoe UI"
BEGIN
    ICON 101, -1, 7, 8, 20, 20
    LTEXT "CatiaMenuWin32", -1, 36, 9, 210, 11
    LTEXT "PyCATIA script launcher for CATIA V5.", -1, 7, 30, 246, 10
    LTEXT "Scripts sourced from KaiUR/Pycatia_Scripts on GitHub.", -1, 7, 42, 246, 10
    LTEXT "Author: Kai-Uwe Rathjen", -1, 7, 62, 246, 10
    LTEXT "AI Assistance: Claude (Anthropic)", -1, 7, 74, 246, 10
    LTEXT "License: MIT", -1, 7, 86, 246, 10
    LTEXT "https://github.com/KaiUR/CatiaMenuWin32", -1, 7, 98, 246, 10
    DEFPUSHBUTTON "OK", 1, 105, 122, 50, 14
END

302 DIALOG 0, 0, 420, 290
STYLE DS_SETFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Script Sources"
FONT 9, "Segoe UI"
BEGIN
    AUTOCHECKBOX "Enable built-in KaiUR/Pycatia_Scripts repository", 608, 7, 7, 380, 12

    GROUPBOX "Additional GitHub Repositories", -1, 7, 24, 406, 136
    CONTROL "", 601, "SysListView32", LVS_REPORT | LVS_SINGLESEL | LVS_SHOWSELALWAYS | WS_BORDER | WS_TABSTOP, 14, 36, 340, 114
    PUSHBUTTON "Add...",        602, 360, 36,  46, 14
    PUSHBUTTON "Edit...",       603, 360, 54,  46, 14
    PUSHBUTTON "Enable/Disable",615, 360, 72,  46, 14
    PUSHBUTTON "Remove",        604, 360, 90,  46, 14

    GROUPBOX "Local Script Folders", -1, 7, 166, 406, 106
    CONTROL "", 605, "SysListView32", LVS_REPORT | LVS_SINGLESEL | LVS_SHOWSELALWAYS | WS_BORDER | WS_TABSTOP, 14, 178, 340, 84
    PUSHBUTTON "Add...",        606, 360, 178, 46, 14
    PUSHBUTTON "Enable/Disable",616, 360, 196, 46, 14
    PUSHBUTTON "Remove",        607, 360, 214, 46, 14

    DEFPUSHBUTTON "OK",     1,  318, 272, 50, 14
    PUSHBUTTON "Cancel",    2,  372, 272, 44, 14
END

303 DIALOG 0, 0, 300, 130
STYLE DS_SETFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Add / Edit Repository"
FONT 9, "Segoe UI"
BEGIN
    LTEXT "GitHub URL:",   -1,   7,  10, 60, 10
    EDITTEXT 610, 72,  8, 222, 14, ES_AUTOHSCROLL
    LTEXT "Branch:",       -1,   7,  28, 60, 10
    EDITTEXT 611, 72, 26, 100, 14, ES_AUTOHSCROLL
    AUTOCHECKBOX "Use token", 613, 7, 48, 60, 12
    EDITTEXT 612, 72, 46, 222, 14, ES_PASSWORD | ES_AUTOHSCROLL
    AUTOCHECKBOX "Enabled",   614, 7, 66, 60, 12
    DEFPUSHBUTTON "OK",     1, 188, 110, 50, 14
    PUSHBUTTON "Cancel",    2, 244, 110, 50, 14
END


304 DIALOG 0, 0, 340, 310
STYLE DS_SETFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Script Details"
FONT 9, "Segoe UI"
BEGIN
    LTEXT "Name:",        -1,   7,   8, 60, 10
    EDITTEXT 701,          72,   6, 262, 14, ES_AUTOHSCROLL | ES_READONLY

    LTEXT "Purpose:",     -1,   7,  26, 60, 10
    EDITTEXT 702,          72,  24, 262, 14, ES_AUTOHSCROLL | ES_READONLY

    LTEXT "Author:",      -1,   7,  44, 60, 10
    EDITTEXT 703,          72,  42, 120, 14, ES_AUTOHSCROLL | ES_READONLY

    LTEXT "Version:",     -1, 200,  44, 40, 10
    EDITTEXT 704,         244,  42,  90, 14, ES_AUTOHSCROLL | ES_READONLY

    LTEXT "Date:",        -1,   7,  62, 60, 10
    EDITTEXT 705,          72,  60, 120, 14, ES_AUTOHSCROLL | ES_READONLY

    LTEXT "Code:",        -1,   7,  80, 60, 10
    EDITTEXT 706,          72,  78, 262, 14, ES_AUTOHSCROLL | ES_READONLY

    LTEXT "Release:",     -1,   7,  98, 60, 10
    EDITTEXT 707,          72,  96, 120, 14, ES_AUTOHSCROLL | ES_READONLY

    LTEXT "Description:", -1,   7, 116, 60, 10
    EDITTEXT 708,          72, 114, 262, 50, ES_MULTILINE | ES_AUTOVSCROLL | ES_READONLY | WS_VSCROLL

    LTEXT "Requirements:", -1,  7, 170, 60, 10
    EDITTEXT 709,           72, 168, 262, 36, ES_MULTILINE | ES_AUTOVSCROLL | ES_READONLY | WS_VSCROLL

    LTEXT "Local path:",  -1,   7, 210, 60, 10
    EDITTEXT 711,          72, 208, 262, 14, ES_AUTOHSCROLL | ES_READONLY

    GROUPBOX "User",      -1,   7, 228, 326, 52
    LTEXT "Note:",        -1,  14, 242, 40, 10
    EDITTEXT 710,          58, 240, 268, 14, ES_AUTOHSCROLL
    AUTOCHECKBOX "Favourite", 712, 14, 260, 70, 12
    AUTOCHECKBOX "Hidden",    713, 90, 260, 60, 12

    DEFPUSHBUTTON "OK",     1, 234, 290, 50, 14
    PUSHBUTTON    "Cancel", 2, 290, 290, 50, 14
END

305 DIALOG 0, 0, 300, 80
STYLE DS_SETFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Run with Arguments"
FONT 9, "Segoe UI"
BEGIN
    LTEXT "Arguments:", -1, 7, 12, 55, 10
    EDITTEXT 720, 66, 10, 227, 14, ES_AUTOHSCROLL
    DEFPUSHBUTTON "Run",    1, 194, 58, 50, 14
    PUSHBUTTON    "Cancel", 2, 248, 58, 50, 14
END

306 DIALOG 0, 0, 300, 90
STYLE DS_SETFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Script Note"
FONT 9, "Segoe UI"
BEGIN
    LTEXT "Note:", -1, 7, 10, 40, 10
    EDITTEXT 721, 7, 22, 286, 36, ES_MULTILINE | ES_AUTOVSCROLL | WS_VSCROLL
    DEFPUSHBUTTON "OK",     1, 194, 70, 50, 14
    PUSHBUTTON    "Cancel", 2, 248, 70, 50, 14
END

307 DIALOG 0, 0, 340, 200
STYLE DS_SETFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Hidden Scripts"
FONT 9, "Segoe UI"
BEGIN
    LTEXT "Scripts listed below are hidden. Select one and click Unhide to restore it.", -1, 7, 7, 326, 18
    CONTROL "", 730, "SysListView32", LVS_REPORT | LVS_SINGLESEL | LVS_SHOWSELALWAYS | WS_BORDER | WS_TABSTOP, 7, 28, 326, 138
    PUSHBUTTON "Unhide",      731, 7,   176, 60, 14
    PUSHBUTTON "Unhide All",  732, 74,  176, 60, 14
    DEFPUSHBUTTON "Close",    2,   284, 176, 50, 14
END


VS_VERSION_INFO VERSIONINFO
FILEVERSION    @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,@BUILD_NUMBER@
PRODUCTVERSION @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,@BUILD_NUMBER@
FILEFLAGSMASK VS_FFI_FILEFLAGSMASK
FILEFLAGS 0
FILEOS VOS_NT_WINDOWS32
FILETYPE VFT_APP
FILESUBTYPE VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904B0"
        BEGIN
            VALUE "CompanyName",      "Kai-Uwe Rathjen"
            VALUE "FileDescription",  "CatiaMenuWin32 - PyCATIA Script Launcher"
            VALUE "FileVersion",      "@PROJECT_VERSION_MAJOR@.@PROJECT_VERSION_MINOR@.@PROJECT_VERSION_PATCH@.@BUILD_NUMBER@"
            VALUE "InternalName",     "CatiaMenuWin32"
            VALUE "LegalCopyright",   "Copyright @CURRENT_YEAR@ Kai-Uwe Rathjen"
            VALUE "OriginalFilename", "CatiaMenuWin32.exe"
            VALUE "ProductName",      "CatiaMenuWin32"
            VALUE "ProductVersion",   "@PROJECT_VERSION_MAJOR@.@PROJECT_VERSION_MINOR@.@PROJECT_VERSION_PATCH@.@BUILD_NUMBER@"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 0x04B0
    END
END
