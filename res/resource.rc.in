#include "resource.h"
#include <windows.h>
#include <commctrl.h>

IDI_APP_ICON ICON "app_icon.ico"
IDI_HELP_ICON ICON "help_icon.ico"

/* ================================================================== */
/*  Settings dialog  (IDD_SETTINGS = 300)  — tabbed                   */
/* ================================================================== */
300 DIALOG 0, 0, 364, 310
STYLE DS_SETFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Settings"
FONT 9, "Segoe UI"
BEGIN
    /* Tab control spanning most of the dialog */
    CONTROL "", 415, "SysTabControl32", TCS_TABS | WS_TABSTOP, 5, 5, 354, 274

    /* ── Tab 0: General ──────────────────────────────────────────── */
    GROUPBOX "Python Interpreter",                              450, 10,  22, 344, 40
    LTEXT    "Path:",                                           451, 16,  37,  24, 10
    EDITTEXT 401,                                                   44,  35, 262, 14, ES_AUTOHSCROLL
    PUSHBUTTON "Browse...",                                     402,310,  34,  40, 16

    GROUPBOX "Script Cache Folder",                             452, 10,  68, 344, 40
    LTEXT    "Path:",                                           453, 16,  83,  24, 10
    EDITTEXT 403,                                                   44,  81, 262, 14, ES_AUTOHSCROLL
    PUSHBUTTON "Browse...",                                     404,310,  80,  40, 16

    GROUPBOX "GitHub Token (optional — raises API rate limit)", 454, 10, 114, 344, 40
    AUTOCHECKBOX "Use token",                                   407, 16, 130,  60, 12
    EDITTEXT 408,                                                   82, 128, 266, 14, ES_PASSWORD | ES_AUTOHSCROLL

    /* ── Tab 1: Sync & Updates ──────────────────────────────────── */
    GROUPBOX "Script Synchronisation",                          455, 10,  22, 344, 108
    AUTOCHECKBOX "Sync scripts automatically on startup",       409, 16,  37, 324, 12
    AUTOCHECKBOX "Always download latest script before running",405, 16,  51, 324, 12
    AUTOCHECKBOX "Check for app updates on startup",            411, 16,  65, 290, 12
    AUTOCHECKBOX "Auto-install updates",                        413, 16,  79, 200, 12
    LTEXT "Auto-refresh every",                                 456, 16,  96,  92, 10
    EDITTEXT 414,                                                  112,  94,  30, 14, ES_NUMBER
    LTEXT "hours  (0 = off)",                                   457,146,  96,  90, 10

    /* ── Tab 2: Console ─────────────────────────────────────────── */
    GROUPBOX "Console Options",                                 458, 10,  22, 344, 62
    AUTOCHECKBOX "Show Python console window when running",     406, 16,  37, 310, 12
    AUTOCHECKBOX "Keep console open after script finishes",     410, 26,  51, 316, 12
    AUTOCHECKBOX "Keep Update Deps console open until closed",  412, 16,  65, 316, 12

    /* ── Tab 3: Window ──────────────────────────────────────────── */
    GROUPBOX "Window Behaviour",                                459, 10,  22, 344, 58
    AUTOCHECKBOX "Always on Top",                               416, 16,  37, 150, 12
    AUTOCHECKBOX "Minimize to Tray",                            417,176,  37, 150, 12
    AUTOCHECKBOX "Start with Windows",                          418, 16,  51, 150, 12
    AUTOCHECKBOX "Start Minimized",                             419,176,  51, 150, 12

    GROUPBOX "Theme",                                           460, 10,  86, 344, 50
    AUTORADIOBUTTON "System (follow Windows)",                  423, 16, 101, 160, 12, WS_GROUP
    AUTORADIOBUTTON "Dark",                                     421,186, 101,  60, 12
    AUTORADIOBUTTON "Light",                                    422,256, 101,  60, 12

    GROUPBOX "Sort Scripts",                                    461, 10, 142, 344, 60
    AUTORADIOBUTTON "Default Order",                            424, 16, 157, 130, 12, WS_GROUP
    AUTORADIOBUTTON "Alphabetical",                             425,160, 157, 120, 12
    AUTORADIOBUTTON "By Date",                                  426, 16, 173, 130, 12
    AUTORADIOBUTTON "Most Used",                                427,160, 173, 120, 12

    /* ── Tab 4: Quick Bar ───────────────────────────────────────── */
    AUTOCHECKBOX "Enable Quick Launch Bar",                     428, 16,  28, 210, 12
    GROUPBOX "Orientation",                                     462, 10,  44, 344, 36
    AUTORADIOBUTTON "Vertical",                                 430, 16,  59, 100, 12, WS_GROUP
    AUTORADIOBUTTON "Horizontal",                               429,126,  59, 100, 12
    AUTOCHECKBOX "Stay on Top with Target Application",         431, 16,  88, 310, 12
    LTEXT "Target application window title substring:",         463, 10, 106, 260, 10
    EDITTEXT 432,                                                   10, 118, 344, 14, ES_AUTOHSCROLL
    LTEXT "(empty = Quick Bar is always visible on screen)",    464, 10, 136, 280, 10
    LTEXT "Target process executable name (e.g. CNEXT.exe):",  465, 10, 154, 260, 10
    EDITTEXT 433,                                                   10, 166, 294, 14, ES_AUTOHSCROLL
    PUSHBUTTON "Browse...",                                     467,308, 165,  46, 16
    LTEXT "(empty = match any process)",                        466, 10, 184, 200, 10

    /* ── Close-group sentinel + bottom buttons ──────────────────── */
    PUSHBUTTON    "Reset to Defaults", 420,   7, 288,  90, 16, WS_GROUP
    DEFPUSHBUTTON "OK",                  1, 224, 288,  68, 16
    PUSHBUTTON    "Cancel",              2, 300, 288,  58, 16
END

/* ================================================================== */
/*  About dialog  (IDD_ABOUT = 301)                                    */
/* ================================================================== */
301 DIALOG 0, 0, 220, 100
STYLE DS_SETFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "About CatiaMenuWin32"
FONT 9, "Segoe UI"
BEGIN
    LTEXT "CatiaMenuWin32", -1, 10, 10, 200, 14
    LTEXT "Native Win32 PyCATIA Script Launcher", -1, 10, 26, 200, 10
    LTEXT "Author: Kai-Uwe Rathjen", -1, 10, 42, 200, 10
    LTEXT "AI Assistance: Claude (Anthropic)", -1, 10, 54, 200, 10
    LTEXT "License: MIT", -1, 10, 66, 200, 10
    DEFPUSHBUTTON "OK", 1, 84, 80, 50, 14
END

/* ================================================================== */
/*  Sources dialog  (IDD_SOURCES = 302)                                */
/* ================================================================== */
302 DIALOG 0, 0, 420, 290
STYLE DS_SETFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Script Sources"
FONT 9, "Segoe UI"
BEGIN
    AUTOCHECKBOX "Enable built-in KaiUR/Pycatia_Scripts repository", 608, 7, 7, 380, 12

    GROUPBOX "Additional GitHub Repositories", -1, 7, 24, 406, 136
    CONTROL "", 601, "SysListView32", LVS_REPORT | LVS_SINGLESEL | LVS_SHOWSELALWAYS | WS_BORDER | WS_TABSTOP, 14, 36, 340, 114
    PUSHBUTTON "Add...",        602, 360, 36,  46, 14
    PUSHBUTTON "Edit...",       603, 360, 54,  46, 14
    PUSHBUTTON "Enable/Disable",615, 360, 72,  46, 14
    PUSHBUTTON "Remove",        604, 360, 90,  46, 14

    GROUPBOX "Local Script Folders", -1, 7, 166, 406, 106
    CONTROL "", 605, "SysListView32", LVS_REPORT | LVS_SINGLESEL | LVS_SHOWSELALWAYS | WS_BORDER | WS_TABSTOP, 14, 178, 340, 84
    PUSHBUTTON "Add...",        606, 360, 178, 46, 14
    PUSHBUTTON "Enable/Disable",616, 360, 196, 46, 14
    PUSHBUTTON "Remove",        607, 360, 214, 46, 14

    DEFPUSHBUTTON "OK",     1,  318, 272, 50, 14
    PUSHBUTTON "Cancel",    2,  372, 272, 44, 14
END

/* ================================================================== */
/*  Repo edit dialog  (IDD_REPO_EDIT = 303)                            */
/* ================================================================== */
303 DIALOG 0, 0, 300, 120
STYLE DS_SETFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Add / Edit Repository"
FONT 9, "Segoe UI"
BEGIN
    LTEXT "Repository URL:", -1, 7, 10, 80, 10
    EDITTEXT 610, 7, 22, 286, 14, ES_AUTOHSCROLL
    LTEXT "Branch:", -1, 7, 42, 40, 10
    EDITTEXT 611, 50, 40, 100, 14, ES_AUTOHSCROLL
    AUTOCHECKBOX "Enabled", 614, 7, 60, 60, 12
    AUTOCHECKBOX "Use token:", 613, 7, 76, 60, 12
    EDITTEXT 612, 70, 74, 220, 14, ES_PASSWORD | ES_AUTOHSCROLL
    DEFPUSHBUTTON "OK",     1, 194, 100, 50, 14
    PUSHBUTTON    "Cancel", 2, 248, 100, 50, 14
END

/* ================================================================== */
/*  Script details dialog  (IDD_SCRIPT_DETAILS = 304)                  */
/* ================================================================== */
304 DIALOG 0, 0, 340, 310
STYLE DS_SETFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Script Details"
FONT 9, "Segoe UI"
BEGIN
    LTEXT "Name:",        -1,   7,   8, 60, 10
    EDITTEXT 701,          72,   6, 262, 14, ES_AUTOHSCROLL | ES_READONLY

    LTEXT "Purpose:",     -1,   7,  26, 60, 10
    EDITTEXT 702,          72,  24, 262, 14, ES_AUTOHSCROLL | ES_READONLY

    LTEXT "Author:",      -1,   7,  44, 60, 10
    EDITTEXT 703,          72,  42, 120, 14, ES_AUTOHSCROLL | ES_READONLY

    LTEXT "Version:",     -1, 200,  44, 40, 10
    EDITTEXT 704,         244,  42,  90, 14, ES_AUTOHSCROLL | ES_READONLY

    LTEXT "Date:",        -1,   7,  62, 60, 10
    EDITTEXT 705,          72,  60, 120, 14, ES_AUTOHSCROLL | ES_READONLY

    LTEXT "Code:",        -1,   7,  80, 60, 10
    EDITTEXT 706,          72,  78, 262, 14, ES_AUTOHSCROLL | ES_READONLY

    LTEXT "Release:",     -1,   7,  98, 60, 10
    EDITTEXT 707,          72,  96, 120, 14, ES_AUTOHSCROLL | ES_READONLY

    LTEXT "Description:", -1,   7, 116, 60, 10
    EDITTEXT 708,          72, 114, 262, 50, ES_MULTILINE | ES_AUTOVSCROLL | ES_READONLY | WS_VSCROLL

    LTEXT "Requirements:", -1,  7, 170, 60, 10
    EDITTEXT 709,           72, 168, 262, 36, ES_MULTILINE | ES_AUTOVSCROLL | ES_READONLY | WS_VSCROLL

    LTEXT "Local path:",  -1,   7, 210, 60, 10
    EDITTEXT 711,          72, 208, 262, 14, ES_AUTOHSCROLL | ES_READONLY

    GROUPBOX "User",      -1,   7, 228, 326, 52
    LTEXT "Note:",        -1,  14, 242, 40, 10
    EDITTEXT 710,          58, 240, 268, 14, ES_AUTOHSCROLL
    AUTOCHECKBOX "Favourite", 712, 14, 260, 70, 12
    AUTOCHECKBOX "Hidden",    713, 90, 260, 60, 12

    DEFPUSHBUTTON "OK",     1, 234, 290, 50, 14
    PUSHBUTTON    "Cancel", 2, 290, 290, 50, 14
END

/* ================================================================== */
/*  Run with args dialog  (IDD_RUN_ARGS = 305)                         */
/* ================================================================== */
305 DIALOG 0, 0, 300, 80
STYLE DS_SETFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Run with Arguments"
FONT 9, "Segoe UI"
BEGIN
    LTEXT "Arguments:", -1, 7, 12, 55, 10
    EDITTEXT 720, 66, 10, 227, 14, ES_AUTOHSCROLL
    DEFPUSHBUTTON "Run",    1, 194, 58, 50, 14
    PUSHBUTTON    "Cancel", 2, 248, 58, 50, 14
END

/* ================================================================== */
/*  Script note dialog  (IDD_SCRIPT_NOTE = 306)                        */
/* ================================================================== */
306 DIALOG 0, 0, 300, 90
STYLE DS_SETFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Script Note"
FONT 9, "Segoe UI"
BEGIN
    LTEXT "Note:", -1, 7, 10, 40, 10
    EDITTEXT 721, 7, 22, 286, 36, ES_MULTILINE | ES_AUTOVSCROLL | WS_VSCROLL
    DEFPUSHBUTTON "OK",     1, 194, 70, 50, 14
    PUSHBUTTON    "Cancel", 2, 248, 70, 50, 14
END

/* ================================================================== */
/*  Hidden scripts dialog  (IDD_HIDDEN_SCRIPTS = 307)                  */
/* ================================================================== */
307 DIALOG 0, 0, 340, 200
STYLE DS_SETFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Hidden Scripts"
FONT 9, "Segoe UI"
BEGIN
    LTEXT "Scripts listed below are hidden. Select one and click Unhide to restore it.", -1, 7, 7, 326, 18
    CONTROL "", 730, "SysListView32", LVS_REPORT | LVS_SINGLESEL | LVS_SHOWSELALWAYS | WS_BORDER | WS_TABSTOP, 7, 28, 326, 138
    PUSHBUTTON "Unhide",      731, 7,  176, 60, 14
    PUSHBUTTON "Unhide All",  732, 74, 176, 60, 14
    DEFPUSHBUTTON "Close",    2,  284, 176, 50, 14
END

/* ================================================================== */
/*  Help dialog  (IDD_HELP = 308)                                      */
/* ================================================================== */
308 DIALOG 0, 0, 580, 380
STYLE DS_SETFONT | WS_POPUP | WS_CAPTION | WS_SYSMENU | WS_SIZEBOX
CAPTION "CatiaMenuWin32 Help"
FONT 9, "Segoe UI"
BEGIN
    LTEXT "", -1, 0, 0, 1, 1
END

/* ================================================================== */
/*  Target App dialog  (IDD_QBAR_TARGET = 309)                        */
/* ================================================================== */
309 DIALOG 0, 0, 300, 108
STYLE DS_SETFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Set Target Application"
FONT 9, "Segoe UI"
BEGIN
    LTEXT "Window title substring (empty = always visible):",  -1,  7, 10, 286, 10
    EDITTEXT 760,                                                    7, 24, 286, 14, ES_AUTOHSCROLL
    LTEXT "Process executable name (e.g. CNEXT.exe):",         -1,  7, 46, 286, 10
    EDITTEXT 761,                                                    7, 60, 236, 14, ES_AUTOHSCROLL
    PUSHBUTTON "Browse...",                                      762,247, 59,  46, 16
    DEFPUSHBUTTON "OK",     1, 188, 86, 50, 14
    PUSHBUTTON    "Cancel", 2, 244, 86, 50, 14
END

VS_VERSION_INFO VERSIONINFO
FILEVERSION @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,@BUILD_NUMBER@
PRODUCTVERSION @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,@BUILD_NUMBER@
FILEFLAGSMASK 0x3fL
FILEFLAGS 0x0L
FILEOS 0x40004L
FILETYPE 0x1L
FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName",      "Kai-Uwe Rathjen"
            VALUE "FileDescription",  "CATIA Macro Menu"
            VALUE "FileVersion",      "@PROJECT_VERSION_MAJOR@.@PROJECT_VERSION_MINOR@.@PROJECT_VERSION_PATCH@.@BUILD_NUMBER@"
            VALUE "InternalName",     "CatiaMenuWin32"
            VALUE "LegalCopyright",   "Copyright (C) @CURRENT_YEAR@ Kai-Uwe Rathjen"
            VALUE "OriginalFilename", "CatiaMenuWin32.exe"
            VALUE "ProductName",      "CatiaMenuWin32"
            VALUE "ProductVersion",   "@PROJECT_VERSION_MAJOR@.@PROJECT_VERSION_MINOR@.@PROJECT_VERSION_PATCH@.@BUILD_NUMBER@"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END

@RC_MANIFEST_LINE@
